{
  "name": "pnpm-release-action",
  "version": "0.0.0",
  "private": true,
  "description": "CI layer for pnpm built-in versioning: release PRs, tags, and GitHub Releases",
  "keywords": [],
  "homepage": "https://github.com/k35o/pnpm-release-action#readme",
  "bugs": "https://github.com/k35o/pnpm-release-action/issues",
